#PROJECT_NAME=OrthovennPlus
SQL_ECHO=false

WEB_PORT=5920
API_PORT=8008
NGINX_PORT=18088

ORTHOVENN_IMAGE_TAG=latest
CELERY_CONCURRENCY=2
INTERACTIVE_WORKER_CONCURRENCY=2
SELECTION_WORKER_CONCURRENCY=2
MODULE_DEFAULT_THREADS=8
MODULE_THREAD_EDITABLE=true
CONDA_PATH=conda
GNU_SORT_BIN=

FIRST_REGISTERED_USER_AS_ADMIN=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=pg.orthovenn_plus
POSTGRES_PASSWORD=change-postgres-password
POSTGRES_DB=postgres-orthovenn-plus

REDIS_HOST=localhost
REDIS_PORT=6379

SECRET_KEY=change-your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=4320

CORS_ORIGINS=http://127.0.0.1:5920,http://localhost:5920

# Upload / tusd tus/simple
UPLOAD_TRANSPORT=tus
PUBLIC_TUS_ENDPOINT=/tus/files/
UPLOAD_MAX_FILE_SIZE=314572800
UPLOAD_CHUNK_SIZE=1048576
TUSD_PORT=1080
# TUSD_CORS_ALLOW_ORIGIN accepts a regex used by tusd -cors-allow-origin.
TUSD_CORS_ALLOW_ORIGIN=.*

# tusd runs in Docker; this lets hooks call the local development backend on the host.
# TUSD_HOOKS_HTTP_URL=http://host.docker.internal:8008/api/core/uploads/tusd/hooks
# For full compose deployment, use:
TUSD_HOOKS_HTTP_URL=http://backend:8000/api/core/uploads/tusd/hooks

# project config
PROJECT_SPECIES_LIMIT=16
PROJECT_VERSION_LIMIT=0
PROJECT_RETENTION_DAYS=30
PROJECT_CLEANUP_SCHEDULER_ENABLED=true
PROJECT_CLEANUP_SCHEDULER_INTERVAL_SECONDS=300
PROJECT_CLEANUP_SCHEDULE_HOUR_UTC=3
PROJECT_CLEANUP_SCHEDULE_MINUTE_UTC=0
# 异常状态的项目清理时间
PROJECT_CLEANUP_STALE_ACTIVE_HOURS=12

# Optional email verification login and password reset.
# 如果要使用邮箱登录，找回密码 需要开启并设置正确的邮箱地址
MAIL_ENABLED=false
MAIL_SMTP_HOST=smtp.163.com
MAIL_SMTP_PORT=465
# 邮箱地址
MAIL_SMTP_USERNAME=your-real-email@163.com
# 授权码 注意 不是邮箱密码
MAIL_SMTP_PASSWORD=replace-with-smtp-authorization-code
MAIL_SMTP_FROM=your-real-email@163.com
MAIL_SMTP_FROM_NAME=OrthoVennPlus
MAIL_SMTP_USE_SSL=true
MAIL_SMTP_USE_TLS=false
